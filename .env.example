# WorkspaceOS Environment Variables
# Copy this to .env and adjust as needed

# MCP Bridge
BRIDGE_PORT=3100
GWS_PATH=gws
GWS_SERVICES=drive,gmail,calendar,sheets,docs,chat

# Optional: gws credentials for headless/CI mode
# GWS_CREDENTIALS_DIR=~/.config/gws

# Optional: AI features (email triage, thread summary, meeting prep)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Model Armor template for agent safety
# GWS_SANITIZE_TEMPLATE=projects/P/locations/L/templates/T
